<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>


    <!--
      Android 12+ themed splash. The system kicks in BEFORE any
      content paints, then transitions to the WebView. We point the
      animated icon at the same launcher foreground we generated for
      the home-screen icon so brand looks consistent across both
      surfaces. The legacy `android:background` is kept as a fallback
      for Android 11 and below, which doesn't honour the
      windowSplashScreen* attributes.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#F10100</item>
        <!--
          Vector splash icon rather than the launcher foreground PNG.
          The launcher foreground (a wide wordmark image) was being
          cropped by Android 12+'s circular mask down to almost
          nothing visible. The vector renders at proper scale inside
          the safe zone with the wordmark intact.
        -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/rajlo_splash_logo</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <item name="android:background">@drawable/splash</item>
    </style>
</resources>