<?xml version="1.0" encoding="utf-8"?>
<!--
  Rajlo splash icon. Used by the Android 12+ themed splash via
  `windowSplashScreenAnimatedIcon` in values/styles.xml.

  This used to be the full Rajlo wordmark, but the wordmark's wide
  aspect ratio shrank to a tiny strip inside Android's circular
  splash icon area — practically unreadable on most devices. The
  brand mark (the "o" ring + arc above it) is much closer to a
  square so it fills the splash slot at proper size, and it's the
  same shape as the launcher icon so the splash-to-app handoff feels
  continuous.

  Path data is the same as `LogoIcon` in `src/components/logo.tsx`
  (viewBox `349 339 130 115`). Drawn in white over the
  `windowSplashScreenBackground` (#111906) defined in styles.xml.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="288dp"
    android:height="288dp"
    android:viewportWidth="288"
    android:viewportHeight="288">
    <group
        android:scaleX="1.6"
        android:scaleY="1.6"
        android:translateX="-518.4"
        android:translateY="-489.6">
        <!-- "O" — hollow ring -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M413.75,363.1c24.55,0,43.87,19.32,43.87,43.34s-19.32,43.34-43.87,43.34-43.86-19.32-43.86-43.34S389.21,363.1,413.75,363.1Zm0,72.06c16.71,0,27.16-12,27.16-28.72s-10.45-28.72-27.16-28.72-27.15,12-27.15,28.72S397,435.16,413.75,435.16Z" />
        <!-- Arc above the O -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M413.53,339.93a64.37,64.37,0,0,0-63.7,55.7H365a49.27,49.27,0,0,1,97,0h15.18A64.37,64.37,0,0,0,413.53,339.93Z" />
    </group>
</vector>
