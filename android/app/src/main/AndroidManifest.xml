<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- Permissions -->
    <!-- Internet — required for the WebView to load driver.rajlo.com / vercel URL -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Location: fine + coarse for the GPS fix itself, background so the
         foreground service keeps streaming once the driver locks the
         screen. The background-geolocation plugin uses these — without
         them the plugin silently degrades to foreground-only tracking. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Foreground service: Android 14+ requires apps using location in
         the background to declare a typed foreground service so users
         can see which apps are tracking them at any moment. The
         background-geolocation plugin runs its service under this type. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Notifications: Android 13+ requires explicit opt-in to show any
         notification, including the foreground-service sticky one. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake lock: keeps the CPU running long enough to deliver a GPS
         fix when the screen is off. Required for reliable background
         tracking on aggressive battery-saving OEMs (Xiaomi, Huawei). -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
</manifest>
