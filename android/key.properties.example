# Rajlo Driver — release signing config.
#
# Copy this file to `android/key.properties` and fill in the real
# values. The actual `key.properties` (and any *.jks / *.keystore
# files) MUST stay out of git — they're already in .gitignore.
#
# storeFile can be either:
#   - a relative path from android/  (e.g. "rajlo-upload-key.jks")
#   - an absolute path               (e.g. "C:/keys/rajlo-upload-key.jks")
#
# storePassword and keyPassword are usually the same for upload keys
# generated by Android Studio, but they can differ if you reused an
# existing keystore.

storeFile=rajlo-upload-key.jks
storePassword=PUT_KEYSTORE_PASSWORD_HERE
keyAlias=PUT_KEY_ALIAS_HERE
keyPassword=PUT_KEY_PASSWORD_HERE
